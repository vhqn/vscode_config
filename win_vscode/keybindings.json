[
    {
        "key": "ctrl+l",
        "command": "workbench.action.chat.icube.open",
        "when": "!isSoloModeContext",
        "isAIItem": true
    },
    {
        "key": "ctrl+u",
        "command": "-workbench.action.chat.icube.open",
        "when": "!isSoloModeContext"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.terminal.clear",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+t",
        "command": "workbench.action.quickOpen"
    }
]
