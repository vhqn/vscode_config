[
    {
        "key": "ctrl+l",
        "command": "runCommands",
        "args": {
            "commands": [
                "claude-vscode.sidebar.open",
                "workbench.action.focusAuxiliaryBar"
            ]
        },
        "when": "!terminalFocus && !claude-vscode.sideBarActive"
    },
    {
        "key": "ctrl+l",
        "command": "runCommands",
        "args": {
            "commands": [
                "claude-vscode.sidebar.open",
                "workbench.action.focusAuxiliaryBar"
            ]
        },
        "when": "terminalFocus && !claude-vscode.sideBarActive"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusAuxiliaryBar",
        "when": "!terminalFocus && claude-vscode.sideBarActive && (editorFocus || panelFocus)"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.closeAuxiliaryBar",
        "when": "!terminalFocus && claude-vscode.sideBarActive && !editorFocus && !panelFocus"
    },
    {
        "key": "ctrl+l",
        "command": "workbench.action.focusAuxiliaryBar",
        "when": "terminalFocus && claude-vscode.sideBarActive"
    },
    {
        "key": "ctrl+b",
        "command": "workbench.action.toggleSidebarVisibility",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+k",
        "command": "workbench.action.terminal.clear",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+t",
        "command": "workbench.action.quickOpen"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.terminal.focus",
        "when": "!terminalFocus"
    },
    {
        "key": "ctrl+j",
        "command": "workbench.action.closePanel",
        "when": "terminalFocus"
    }
]
