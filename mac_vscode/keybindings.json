// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+l",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "auxiliaryBarVisible && !(editorTextFocus && editorHasSelection)"
    },
    {
        "key": "cmd+l",
        "command": "runCommands",
        "when": "editorTextFocus && editorHasSelection",
        "args": {
            "commands": [
                "chatgpt.addToThread",
                "chatgpt.openSidebar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    },
    {
        "key": "cmd+l",
        "command": "runCommands",
        "when": "!auxiliaryBarVisible && (!editorTextFocus || !editorHasSelection)",
        "args": {
            "commands": [
                "chatgpt.openSidebar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    },
    {
        "key": "cmd+i",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "auxiliaryBarVisible"
    },
    {
        "key": "cmd+i",
        "command": "runCommands",
        "when": "!auxiliaryBarVisible",
        "args": {
            "commands": [
                "claude-vscode.sidebar.open",
                "claude-vscode.focus"
            ]
        }
    },
    {
        "key": "cmd+t",
        "command": "-workbench.action.showAllSymbols"
    },
    {
        "key": "cmd+t",
        "command": "workbench.action.quickOpen"
    },
    {
        "key": "cmd+shift+l",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "auxiliaryBarVisible && !editorTextFocus && !terminalFocus"
    },
    {
        "key": "cmd+shift+l",
        "command": "runCommands",
        "when": "editorTextFocus && editorHasSelection",
        "args": {
            "commands": [
                "chatgpt.addToThread",
                "chatgpt.openSidebar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    },
    {
        "key": "cmd+shift+l",
        "command": "runCommands",
        "when": "editorTextFocus && !editorHasSelection",
        "args": {
            "commands": [
                "chatgpt.openSidebar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    },
    {
        "key": "cmd+shift+l",
        "command": "runCommands",
        "when": "terminalFocus",
        "args": {
            "commands": [
                "chatgpt.openSidebar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    },
    {
        "key": "cmd+r cmd+w",
        "command": "workbench.action.closeAllEditors"
    }
]
