// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+l",
        "command": "workbench.action.toggleAuxiliaryBar",
        "when": "auxiliaryBarVisible"
    },
    {
        "key": "cmd+l",
        "command": "runCommands",
        "when": "!auxiliaryBarVisible",
        "args": {
            "commands": [
                "chatgpt.openSidebar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    }
]
